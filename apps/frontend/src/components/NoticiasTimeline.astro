---
import type { Noticia } from "@adapters/contracts";

type Props = { noticias: Noticia[] };
const { noticias } = Astro.props;

const porAnio = new Map<string, Noticia[]>();
for (const noticia of noticias) {
  const anio = noticia.fecha.slice(0, 4);
  const lista = porAnio.get(anio) ?? [];
  if (lista.length < 3) lista.push(noticia);
  porAnio.set(anio, lista);
}
const anios = [...porAnio.keys()].sort().reverse();
---

<aside class="timeline" aria-labelledby="timeline-titulo">
  <button type="button" class="timeline__scroll" data-dir="-1" aria-label="Desplazar hacia arriba">▲</button>

  <div class="timeline__body">
    <h3 id="timeline-titulo">Noticias</h3>
    <div class="timeline__list">
      {anios.map((anio) => (
        <section class="timeline__year">
          <h4>{anio}</h4>
          <ul>
            {porAnio.get(anio)!.map((noticia) => (
              <li>
                <a href={noticia.url} target="_blank" rel="noopener noreferrer">{noticia.titulo}</a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>

  <button type="button" class="timeline__scroll" data-dir="1" aria-label="Desplazar hacia abajo">▼</button>
</aside>

<script>
  document.querySelectorAll<HTMLElement>(".timeline").forEach((timeline) => {
    const list = timeline.querySelector<HTMLElement>(".timeline__list");
    timeline.querySelectorAll<HTMLButtonElement>(".timeline__scroll").forEach((btn) => {
      btn.addEventListener("click", () => {
        const dir = Number(btn.dataset.dir);
        list?.scrollBy({ top: dir * 160, behavior: "smooth" });
      });
    });
  });
</script>

<style>
  .timeline {
    background: var(--color-nav-bg-active);
    color: var(--color-nav-text);
    height: 100%;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: var(--space-4);
  }

  .timeline__scroll {
    border: none;
    background: none;
    color: var(--color-nav-text);
    cursor: pointer;
    font-size: 1.1rem;
    padding: var(--space-2);
  }

  .timeline__body h3 {
    font-family: var(--font-display);
    text-align: center;
    text-transform: uppercase;
  }

  .timeline__list {
    overflow-y: auto;
    max-height: 480px;
    display: grid;
    gap: var(--space-6);
  }

  .timeline__year h4 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin-bottom: var(--space-2);
  }

  .timeline__year ul {
    list-style: disc;
    padding-inline-start: 1.2rem;
    display: grid;
    gap: var(--space-3);
  }

  .timeline__year a {
    color: var(--color-nav-text);
  }
</style>
