---
// Footer fijo según cotización: logos, texto de cierre, redes, link web — no editable desde WP
import logoLockup from "../assets/logo-fondo-en-paz.svg";
---

<footer class="site-footer" id="contacto">
  <div class="site-footer__media">
    <img
      src="https://placehold.co/900x900/1c1917/ffffff?text=Foto"
      alt=""
      class="site-footer__photo"
      loading="lazy"
    />
    <span class="site-footer__burst" aria-hidden="true"></span>
  </div>

  <div class="site-footer__panel">
    <button class="site-footer__totop" type="button" aria-label="Volver arriba">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" aria-hidden="true">
        <path d="M5 15l7-7 7 7" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>

    <img src={logoLockup.src} alt="Fondo Colombia en Paz — La Paz Sí Pasa, pasa en los territorios" class="site-footer__logo" />

    <p class="site-footer__text">
      Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod
      tincidunt ut laoreet dolore magna aliquam erat volutpat.
    </p>

    <div class="site-footer__social">
      <p class="site-footer__social-label">SÍGUENOS:</p>
      <ul class="site-footer__links">
        <li>
          <a href="https://www.fcp.gov.co" target="_blank" rel="noopener noreferrer">
            <span class="site-footer__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6" />
                <path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18" stroke="currentColor" stroke-width="1.6" />
              </svg>
            </span>
            fcp.gov.co
          </a>
        </li>
        <li>
          <a href="https://www.instagram.com/fondo_colombiaenpaz" target="_blank" rel="noopener noreferrer">
            <span class="site-footer__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none">
                <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.6" />
                <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6" />
                <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" />
              </svg>
            </span>
            @fondo_colombiaenpaz
          </a>
        </li>
        <li>
          <a href="https://x.com/fcolombiaenpaz" target="_blank" rel="noopener noreferrer">
            <span class="site-footer__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none">
                <path d="M5 5l14 14M19 5L5 19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
              </svg>
            </span>
            @fcolombiaenpaz
          </a>
        </li>
      </ul>
    </div>
  </div>
</footer>

<script>
  const toTopButton = document.querySelector<HTMLButtonElement>(".site-footer__totop");
  toTopButton?.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
</script>

<style>
  .site-footer {
    display: grid;
    grid-template-columns: minmax(220px, 30%) 1fr;
    background: var(--color-surface, #fff);
  }

  .site-footer__media {
    position: relative;
    overflow: hidden;
  }

  .site-footer__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ponytail: forma "rota" aproximada por clip-path, no vector final del diseño */
  .site-footer__burst {
    position: absolute;
    left: -10%;
    bottom: 10%;
    width: 55%;
    height: 45%;
    background: var(--color-surface, #fff);
    clip-path: polygon(
      50% 0%, 61% 15%, 80% 5%, 78% 25%, 100% 30%, 85% 45%, 100% 60%,
      80% 62%, 85% 82%, 65% 72%, 60% 92%, 45% 78%, 30% 95%, 28% 75%,
      8% 80%, 18% 60%, 0% 50%, 18% 40%, 5% 20%, 25% 25%, 30% 5%, 42% 18%
    );
  }

  .site-footer__panel {
    position: relative;
    background: var(--color-nav-bg-active, #cbe9f8);
    padding: var(--space-8, 2rem) var(--space-10, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-5, 1.25rem);
    justify-content: center;
  }

  .site-footer__totop {
    position: absolute;
    top: var(--space-6, 1.5rem);
    right: var(--space-6, 1.5rem);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: var(--color-nav-text, #32509d);
    display: grid;
    place-items: center;
    cursor: pointer;
  }

  .site-footer__logo {
    width: min(320px, 100%);
    height: auto;
  }

  .site-footer__text {
    max-width: 46ch;
    color: var(--color-nav-text, #32509d);
    line-height: 1.5;
  }

  .site-footer__social-label {
    font-family: var(--font-display, sans-serif);
    letter-spacing: 0.04em;
    color: var(--color-nav-text, #32509d);
    margin-bottom: var(--space-2, 0.5rem);
  }

  .site-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4, 1rem);
  }

  .site-footer__links li {
    padding-left: var(--space-4, 1rem);
    border-left: 1px solid var(--color-nav-border, #32509d);
  }

  .site-footer__links li:first-child {
    padding-left: 0;
    border-left: none;
  }

  .site-footer__links a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2, 0.5rem);
    color: var(--color-nav-text, #32509d);
    text-decoration: none;
    font-size: 0.9rem;
  }

  .site-footer__icon {
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-surface, #fff);
    color: var(--color-nav-text, #32509d);
  }

  @media (max-width: 720px) {
    .site-footer {
      grid-template-columns: 1fr;
    }

    .site-footer__media {
      aspect-ratio: 16 / 9;
    }

    .site-footer__panel {
      padding: var(--space-6, 1.5rem);
    }
  }
</style>
