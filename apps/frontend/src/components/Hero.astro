---
import { Image } from "astro:assets";
import heroImage from "../assets/hero/hero-image.png";
import heroLogo from "../assets/hero/hero-logo.svg";
---

<section class="hero">
  <Image src={heroImage} alt="" class="hero__bg" loading="eager" />
  <img src={heroLogo.src} alt="La Paz Sí Pasa" class="hero__logo" width="420" />
</section>

<style>
  .hero {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 60vh;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-height: 70vh;
    object-fit: cover;
    z-index: -1;
  }

  .hero__logo {
    width: 100%;
    max-width: 960px;
    padding-inline: 24px;
    height: auto;
    filter: drop-shadow(0 6px 24px rgb(0 0 0 / 85%));
  }

  @media (max-width: 849px) {
    .hero__logo {
      padding-inline: 16px;
    }
  }
</style>
