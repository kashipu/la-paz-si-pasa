---
type Props = {
  imageUrl?: string;
  imageAlt?: string;
  href?: string;
};

// ponytail: placeholder hasta tener el asset final y la URL de la página de noticias
const {
  imageUrl = "https://picsum.photos/seed/banner-noticias/1200/300",
  imageAlt = "Más noticias del fondo aquí",
  href = "#",
} = Astro.props;
---

<a href={href} class="banner-cta">
  <img src={imageUrl} alt={imageAlt} loading="lazy" />
</a>

<style>
  .banner-cta {
    display: block;
    height: 150px;
  }

  .banner-cta img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
