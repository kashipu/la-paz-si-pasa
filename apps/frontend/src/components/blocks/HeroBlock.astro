---
type Props = {
  eyebrow?: string;
  title?: string;
  summary?: string;
  variant?: "split" | "centered" | "editorial";
  tone?: "light" | "brand";
  ctaLabel?: string;
  ctaUrl?: string;
  innerBlocks?: unknown[];
};

const {
  eyebrow,
  title = "Headless WordPress + Astro",
  summary,
  variant = "split",
  tone = "light",
  ctaLabel,
  ctaUrl,
} = Astro.props;
---

<section class:list={["hero", `hero--${variant}`, `hero--${tone}`]}>
  <div class="hero__inner">
    <div class="hero__content">
      {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      {summary && <p class="hero__summary">{summary}</p>}
      {ctaUrl && <a class="hero__cta" href={ctaUrl}>{ctaLabel || "Ver mas"}</a>}
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-16);
    background: var(--color-surface);
  }

  .hero--brand {
    background: var(--color-brand);
    color: var(--color-surface);
  }

  .hero--brand h1 {
    color: var(--color-surface);
  }

  .hero__inner {
    width: min(100% - 2rem, var(--wide-width));
    margin-inline: auto;
  }

  .hero__content {
    display: grid;
    max-width: 48rem;
    gap: var(--space-5);
  }

  .hero--centered .hero__content {
    margin-inline: auto;
    text-align: center;
  }

  .hero__eyebrow {
    color: var(--color-accent);
    font-weight: 700;
    text-transform: uppercase;
  }

  .hero__summary {
    color: color-mix(in srgb, currentColor 78%, transparent);
    font-size: 1.2rem;
  }

  .hero__cta {
    width: fit-content;
    border-radius: var(--radius-control);
    background: var(--color-accent);
    color: white;
    font-weight: 700;
    padding: var(--space-3) var(--space-5);
    text-decoration: none;
  }

  .hero--centered .hero__cta {
    margin-inline: auto;
  }
</style>
