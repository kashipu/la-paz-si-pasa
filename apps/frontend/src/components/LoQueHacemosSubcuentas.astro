---
import type { Subcuenta } from "@adapters/contracts";

type Props = { subcuentas: Subcuenta[] };
const { subcuentas } = Astro.props;
---

<div class="subcuentas" aria-label="Subcuentas del fondo">
  <button type="button" class="subcuentas__nav" data-dir="-1" aria-label="Anterior">‹</button>

  <ul class="subcuentas__track">
    {subcuentas.map((subcuenta) => (
      <li>
        <img src={subcuenta.iconoUrl} alt={subcuenta.nombre} loading="lazy" />
      </li>
    ))}
  </ul>

  <button type="button" class="subcuentas__nav" data-dir="1" aria-label="Siguiente">›</button>
</div>

<script>
  document.querySelectorAll<HTMLElement>(".subcuentas").forEach((subcuentas) => {
    const track = subcuentas.querySelector<HTMLElement>(".subcuentas__track");
    subcuentas.querySelectorAll<HTMLButtonElement>(".subcuentas__nav").forEach((btn) => {
      btn.addEventListener("click", () => {
        const dir = Number(btn.dataset.dir);
        track?.scrollBy({ left: dir * 180, behavior: "smooth" });
      });
    });
  });
</script>

<style>
  .subcuentas {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    max-width: 100%;
    min-width: 0;
  }

  .subcuentas__track {
    list-style: none;
    margin: 0;
    padding: var(--space-2) 0;
    display: flex;
    flex: 1 1 auto;
    gap: var(--space-4);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    min-width: 0;
    scrollbar-width: none;
  }

  .subcuentas__track::-webkit-scrollbar {
    display: none;
  }

  .subcuentas__track li {
    scroll-snap-align: start;
    flex: none;
  }

  .subcuentas__track img {
    display: block;
    height: 72px;
    width: auto;
    object-fit: contain;
  }

  .subcuentas__nav {
    flex: none;
    border: none;
    background: none;
    color: var(--color-nav-text);
    font-size: 1.5rem;
    cursor: pointer;
    padding: var(--space-2);
  }

  @media (max-width: 360px) {
    .subcuentas__track li {
      flex: 1 0 100%;
      width: 100%;
    }

    .subcuentas__track img {
      width: 100%;
      height: auto;
    }
  }
</style>
