---
const items = [
  { href: "/#lo-que-hacemos", label: "Lo que hacemos" },
  { href: "/proyectos-destacados", label: "Proyectos destacados" },
  { href: "/#actualidad", label: "Actualidad" },
];
---

<nav class="nav" aria-label="Principal">
  <button type="button" class="nav__toggle" aria-expanded="false" aria-controls="nav-list">
    <span class="nav__toggle-bar"></span>
    <span class="nav__toggle-bar"></span>
    <span class="nav__toggle-bar"></span>
    <span class="nav__toggle-label">Menú</span>
  </button>
  <ul class="nav__list" id="nav-list">
    {items.map((item) => (
      <li><a href={item.href}>{item.label}</a></li>
    ))}
  </ul>
</nav>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".nav__toggle");
  const list = document.querySelector<HTMLUListElement>(".nav__list");

  toggle?.addEventListener("click", () => {
    const isOpen = list?.classList.toggle("is-open");
    toggle.setAttribute("aria-expanded", String(Boolean(isOpen)));
  });
</script>

<style>
  .nav {
    width: min(100% - 2rem, var(--wide-width));
    margin-inline: auto;
    padding-block: var(--space-4);
  }

  .nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  .nav__list a {
    display: block;
    text-align: center;
    padding-block: var(--space-3);
    border: 1px solid var(--color-nav-border);
    color: var(--color-nav-text);
    font-family: var(--font-display);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    background: var(--color-surface);
    transition: background-color 0.15s ease;
    line-height: 1.5;
  }

  .nav__list a:hover,
  .nav__list a:focus-visible {
    background: var(--color-nav-bg-active);
  }

  .nav__toggle {
    display: none;
  }

  @media (max-width: 760px) {
    .nav__toggle {
      display: grid;
      place-items: center;
      gap: 4px;
      width: 44px;
      height: 44px;
      border: 1px solid var(--color-nav-border);
      border-radius: var(--radius-control);
      background: var(--color-surface);
      position: fixed;
      top: var(--space-4);
      right: var(--space-4);
      z-index: 20;
      cursor: pointer;
    }

    .nav__toggle-bar {
      width: 20px;
      height: 2px;
      background: var(--color-nav-text);
    }

    .nav__toggle-label {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
    }

    .nav__list {
      position: fixed;
      inset: 0;
      z-index: 10;
      display: none;
      grid-template-columns: 1fr;
      align-content: center;
      background: var(--color-surface);
      padding: var(--space-4);
    }

    .nav__list.is-open {
      display: grid;
    }
  }
</style>
