---
import type { Noticia } from "@adapters/contracts";

type Props = { noticias: Noticia[] };
const { noticias } = Astro.props;

const porAnio = new Map<string, Noticia[]>();
for (const noticia of noticias) {
  const anio = noticia.fecha.slice(0, 4);
  const lista = porAnio.get(anio) ?? [];
  if (lista.length < 3) lista.push(noticia);
  porAnio.set(anio, lista);
}
const anios = [...porAnio.keys()].sort().reverse();
---

<aside class="timeline" aria-labelledby="timeline-titulo">
  <button type="button" class="timeline__scroll" data-dir="-1" aria-label="Desplazar hacia arriba">▲</button>

  <div class="timeline__body">
    <h3 id="timeline-titulo">Noticias</h3>
    <div class="timeline__list">
      {anios.map((anio) => (
        <div class="timeline__row">
          <div class="timeline__year">{anio}</div>
          <ul class="timeline__news">
            {porAnio.get(anio)!.map((noticia) => (
              <li>
                <a href={noticia.url} target="_blank" rel="noopener noreferrer">{noticia.titulo}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <button type="button" class="timeline__scroll" data-dir="1" aria-label="Desplazar hacia abajo">▼</button>
</aside>

<script>
  document.querySelectorAll<HTMLElement>(".timeline").forEach((timeline) => {
    const list = timeline.querySelector<HTMLElement>(".timeline__list");
    const rows = [...timeline.querySelectorAll<HTMLElement>(".timeline__row")];
    if (!list) return;
    timeline.querySelectorAll<HTMLButtonElement>(".timeline__scroll").forEach((btn) => {
      btn.addEventListener("click", () => {
        const dir = Number(btn.dataset.dir);
        const current = list.scrollTop;
        const target =
          dir > 0
            ? rows.find((row) => row.offsetTop > current + 4)
            : [...rows].reverse().find((row) => row.offsetTop < current - 4);
        list.scrollTo({ top: target ? target.offsetTop : dir > 0 ? list.scrollHeight : 0, behavior: "smooth" });
      });
    });
  });
</script>

<style>
  #timeline-titulo {
    font-family: var(--font-monique-regular);
    text-align: center;
    text-transform: uppercase;
    color: var(--color-nav-text);
  }
  .timeline {
    background: var(--color-nav-bg-active);
    color: var(--color-nav-text);
    height: 100%;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: var(--space-4);
  }

  .timeline__scroll {
    border: none;
    background: none;
    color: var(--color-nav-text);
    cursor: pointer;
    font-size: 1.1rem;
    padding: var(--space-2);
  }

  .timeline__body h3 {
    font-family: var(--font-monique-regular);
    text-align: center;
    text-transform: uppercase;
  }

  .timeline__list {
    overflow-y: auto;
    max-height: 480px;
    scrollbar-width: thin;
    scrollbar-color: var(--color-nav-text) transparent;
  }

  .timeline__list::-webkit-scrollbar {
    width: 6px;
  }

  .timeline__list::-webkit-scrollbar-track {
    background: transparent;
  }

  .timeline__list::-webkit-scrollbar-thumb {
    background-color: #3b8fd4;
    border-radius: 3px;
  }

  .timeline__row {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: var(--space-4);
  }

  .timeline__row + .timeline__row {
    border-top: 2px solid rgba(255, 255, 255, 0.6);
  }

  .timeline__year {
    font-family: var(--font-monique-regular);
    font-size: 1.5rem;
    padding: var(--space-4) var(--space-2);
    border-right: 2px solid rgba(255, 255, 255, 0.6);
  }

  .timeline__news {
    list-style: disc;
    padding: var(--space-4) var(--space-4) var(--space-4) 1.2rem;
    display: grid;
    gap: var(--space-3);
  }

  .timeline__news a {
    color: var(--color-nav-text);
    text-decoration: none;
  }
</style>
