---
import type { Retrato } from "@adapters/contracts";
import IntroText from "@components/IntroText.astro";
import RetratosPazSlider from "@components/RetratosPazSlider.astro";

type Props = { retratos: Retrato[] };
const { retratos } = Astro.props;
---

<section class="retratos-paz">
  <IntroText />
  <RetratosPazSlider retratos={retratos} />
</section>

<style>
  .retratos-paz {
    display: grid;
    gap: var(--space-8, 2rem);
  }

  .retratos-paz > * {
    min-width: 0;
  }

  @media (min-width: 1024px) {
    .retratos-paz {
      grid-template-columns: 35% 1fr;
      align-items: start;
    }
  }
</style>
