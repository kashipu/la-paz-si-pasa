---
type Props = {
  titulo?: string;
  parrafos?: string[];
  ctaLabel?: string;
  ctaHref?: string;
};

const {
  titulo = "Somos el principal vehículo financiero e institucional",
  parrafos = [
    "Encargado de garantizar la transparencia, eficiencia y agilidad en la ejecución de los recursos para la implementación de la paz en el país.",
    "A través de subcuentas estratégicas, articulamos la inversión en proyectos de desarrollo rural, conservación ambiental, infraestructura y fortalecimiento de economías locales. Conectamos la gestión institucional y la cooperación internacional con las necesidades reales de los territorios PDET para consolidar un progreso seguro, sostenible y transparente.",
  ],
  ctaLabel = "Conoce las subcuentas",
  ctaHref = "#subcuentas",
} = Astro.props;
---

<div class="destacado">
  <h3>{titulo}</h3>
  {parrafos.map((parrafo) => <p>{parrafo}</p>)}
  <a href={ctaHref} class="destacado__cta">{ctaLabel}:</a>
</div>

<style>
  .destacado {
    color: var(--color-nav-text);
  }

  .destacado h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.4;
  }

  .destacado__cta {
    display: inline-block;
    margin-top: var(--space-4);
    font-family: var(--font-display);
    text-transform: uppercase;
    color: var(--color-nav-text);
  }
</style>
