---
import "../styles/global.css";
import Footer from "@components/Footer.astro";
import Nav from "@components/Nav.astro";
import NavMenu from "@components/NavMenu.astro";

type Props = {
  title?: string;
  description?: string;
};

const siteName = "La Paz Sí Pasa";
const title = Astro.props.title ? `${Astro.props.title} | ${siteName}` : siteName;
const description = Astro.props.description ?? "Cierre de gestión del Fondo Colombia en Paz";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'></svg>" />
    <title>{title}</title>
  </head>
  <body>
    <slot name="header" />
    <slot name="hero" />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
