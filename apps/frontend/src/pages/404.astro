---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="No encontrado">
  <section class="not-found">
    <div>
      <h1>Pagina no encontrada</h1>
      <p>El contenido solicitado no existe o cambio de direccion.</p>
      <a href="/">Volver al inicio</a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 50vh;
    display: grid;
    place-items: center;
    padding: var(--space-16) var(--space-4);
    text-align: center;
  }

  .not-found div {
    display: grid;
    gap: var(--space-4);
  }
</style>
